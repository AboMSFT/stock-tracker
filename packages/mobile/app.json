{
  "expo": {
    "name": "Inwealthment",
    "slug": "inwealthment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "inwealthment",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14",
      "enableFullScreenImage_legacy": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.abohoseini.inwealthment",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f14"
      },
      "package": "com.abohoseini.inwealthment"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f0f14"
        }
      ],
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
